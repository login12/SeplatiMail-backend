# ============================================================
# Seplati Mail — Backend Environment Variables
# ============================================================
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env no git!

# --------------- Aplicação ---------------
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1

# --------------- Banco de Dados ---------------
# Use uma database separada da sua outra aplicação
DATABASE_URL="postgresql://SEU_USUARIO:SUA_SENHA@localhost:5432/seplati_mail"

# --------------- JWT ---------------
# Gere com: openssl rand -base64 64
JWT_ACCESS_SECRET="GERE_UMA_CHAVE_SECRETA_FORTE_AQUI"
JWT_REFRESH_SECRET="GERE_OUTRA_CHAVE_SECRETA_FORTE_AQUI"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# --------------- Criptografia (AES-256) ---------------
# Gere com: openssl rand -hex 32
ENCRYPTION_KEY="GERE_UMA_CHAVE_HEX_DE_64_CARACTERES_AQUI"

# --------------- CORS ---------------
FRONTEND_URL="http://localhost:3000"

# --------------- Cookie ---------------
COOKIE_SECRET="GERE_UM_SEGREDO_PARA_COOKIE_AQUI"
